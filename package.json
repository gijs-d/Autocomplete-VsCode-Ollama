{
  "name": "autocomplete",
  "displayName": "autocomplete",
  "description": "",
  "version": "0.0.5",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:python",
    "onLanguage:java",
    "onCommand:autocompleter.generateCommit"
  ],
  "extensionDependencies": [
    "vscode.git"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Ollama Autocomplete JS Configuration",
      "properties": {
        "autocompleter.ollamaHost": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "The URL of your local Ollama server."
        },
        "autocompleter.ollamaModel": {
          "type": "string",
          "default": "qwen2.5-coder:1.5b",
          "description": "The Ollama model to use for autocomplete suggestions (e.g., 'codellama', 'deepseek-coder')."
        }
      }
    },
    "commands": [
      {
        "command": "autocompleter.generateCommit",
        "title": "AI Commit",
        "icon": "$(sparkle)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "autocompleter.generateCommit",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.47.0"
  }
}
